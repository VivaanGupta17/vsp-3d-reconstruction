# ============================================================
# VSP-3D .gitignore
# ============================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.pyo
.Python

# Virtual environments
.env
.venv
env/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/
*.ipynb
!notebooks/*.ipynb

# Data — never commit patient data
/data/
*.dcm
*.DCM
*.nii
*.nii.gz
!tests/fixtures/**/*.nii.gz

# Model checkpoints (large files)
models/
checkpoints/
*.pt
*.pth
*.ckpt
!tests/fixtures/**/*.pt

# Outputs
outputs/
/evaluation/

# STL outputs (large binary)
*.stl
*.STL
*.obj
*.OBJ

# Reports
*.pdf
*.html

# Logs
*.log
logs/

# Coverage
.coverage
htmlcov/
.pytest_cache/

# MyPy
.mypy_cache/

# Distribution packaging
*.tar.gz
*.whl

# SimpleITK temp files
*.mhd
*.raw

# VTK temp files
*.vtp
*.vtu

# Config secrets
.env.local
secrets.yaml

# OS
.DS_Store
.AppleDouble
.LSOverride
ehthumbs.db
Desktop.ini
